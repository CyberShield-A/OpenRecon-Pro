# OpenRecon Pro — Configuration Template
# Copiez ce fichier en .env et adaptez les valeurs

# Modèle Ollama utilisé pour la génération des rapports IA
OLLAMA_MODEL=llama3.1:8b

# Serveur Ollama (par défaut : local)
OLLAMA_HOST=http://localhost:11434

# Port du serveur GUI
GUI_PORT=8080

# Mode de scan par défaut : NORMAL, STEALTH, AGGRESSIVE
DEFAULT_SCAN_MODE=NORMAL

# Timeout des requêtes HTTP (secondes)
REQUEST_TIMEOUT=10
