# OpenRecon Pro — Configuration Template
# Copiez ce fichier en .env et adaptez les valeurs

# Modèle Ollama utilisé pour la génération des rapports IA
OLLAMA_MODEL=llama3.1:8b

# Serveur Ollama (par défaut : local)
OLLAMA_HOST=http://localhost:11434

# Port du serveur GUI
GUI_PORT=8080

# Mode de scan par défaut : NORMAL, STEALTH, AGGRESSIVE
DEFAULT_SCAN_MODE=NORMAL

# Timeout des requêtes HTTP (secondes)
REQUEST_TIMEOUT=10


# --- FICHIER DE CONFIGURATION TEMPLATE ---
# Pour configurer ton environnement local, suis ces étapes :
# 1. Copie ce fichier : cp .env.example .env
# 2. Modifie le fichier .env avec tes propres valeurs.
# 3. NE JAMAIS COMMIT le fichier .env sur GitHub (il est ignoré par le .gitignore).

# Utilisateur de la base de données (tu peux laisser par défaut)
SONAR_DB_USER=sonar

# Mot de passe de la base de données
# ATTENTION : Remplace 'change_me_to_a_secure_password' par un vrai mot de passe robuste.
SONAR_DB_PASSWORD=change_me_to_a_secure_password
